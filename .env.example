# Copy to `.env` for local development (never commit secrets).

# Qdrant (use http://qdrant:6333 only when overriding docker-compose defaults)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=h1_disclosures
# Set to true so the API refuses to start if Qdrant is down
QDRANT_STRICT=false

# Embeddings (FastEmbed; vector size must match model)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_VECTOR_SIZE=384
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Optional: protect POST /v1/engagement/run and /v1/strategist/run (header X-API-Key)
# PENGOD_API_KEY=

# Strategist pipeline (Ollama must be reachable from the API process)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# STRATEGIST_MODEL=llama3:latest
# STRATEGIST_RAG_LIMIT=10
# Small VPS: cap prompt and Ollama KV cache (bytes-heavy)
# STRATEGIST_MAX_USER_CHARS=12000
# STRATEGIST_OLLAMA_NUM_CTX=4096
# STRATEGIST_OLLAMA_NUM_PREDICT=1536

# Streamlit UI only: Groq cloud LLM (never commit real keys)
# GROQ_API_KEY=
