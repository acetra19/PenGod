# Copy to `.env` for local development (never commit secrets).

# Qdrant (use http://qdrant:6333 only when overriding docker-compose defaults)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=h1_disclosures
# Set to true so the API refuses to start if Qdrant is down
QDRANT_STRICT=false

# Embeddings (FastEmbed; vector size must match model)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_VECTOR_SIZE=384
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
